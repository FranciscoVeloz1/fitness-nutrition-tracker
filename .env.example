# Local Vite / preview: absolute API origin (no trailing slash).
VITE_API_BASE_URL=http://localhost:3000

# Production (GitHub Pages): do not put the prod URL here.
# Set repository secret VITE_API_BASE_URL (Settings → Secrets and variables → Actions).
# The deploy workflow injects it at build time. Also add the Pages origin to
# personal-api CORS_ORIGINS, e.g. https://franciscoveloz1.github.io
